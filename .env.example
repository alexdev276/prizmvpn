APP_NAME=Prizm VPN
APP_ENV=local
DEBUG=true
BASE_URL=http://localhost:8000

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/prizm_vpn
SECRET_KEY=replace-with-long-random-secret
ADMIN_EMAILS=admin@example.com

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
SMTP_FROM_NAME=Prizm VPN
SMTP_STARTTLS=true
SMTP_SSL_TLS=false

EMAIL_PROVIDER=smtp
MS_GRAPH_TENANT=consumers
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
MS_GRAPH_REFRESH_TOKEN=
MS_GRAPH_SAVE_TO_SENT_ITEMS=true

REMNA_BASE_URL=https://panel.example.com
REMNA_TOKEN=
REMNA_MOCK_MODE=true
REMNA_DEFAULT_DAYS=30
REMNA_TRAFFIC_LIMIT_BYTES=107374182400
REMNA_SUBSCRIPTION_PATH_TEMPLATE=/api/sub/{uuid}

YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_WEBHOOK_SECRET=
YOOKASSA_TEST_MODE=true

CRYPTOCLOUD_API_KEY=
CRYPTOCLOUD_SHOP_ID=
CRYPTOCLOUD_WEBHOOK_SECRET=
CRYPTOCLOUD_TEST_MODE=true
